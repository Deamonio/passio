{
  "name": "sikdorak-service",
  "version": "1.0.0",
  "private": true,
  "description": "Sikdorak web service with Nginx + Express",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "sync:web": "bash scripts/sync-static-to-remote.sh",
    "deploy:remote:static": "bash scripts/sync-static-to-remote.sh",
    "deploy:local": "bash scripts/deploy.sh",
    "deploy:remote:full": "bash scripts/deploy-remote-full.sh",
    "deploy:remote:pull": "bash scripts/remote-git-pull.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.1"
  }
}
